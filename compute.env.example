# =============================================================================
# Remote Compute Configuration — TEMPLATE
# =============================================================================
# Copy this to `compute.env` and fill in your values.
# `compute.env` is gitignored — never commit it.
#
# Works with SF Compute, AWS EC2, GCP, Azure, RunPod, Vast.ai, Lambda Labs...
# =============================================================================

# -----------------------------------------------------------------------------
# Provider
# -----------------------------------------------------------------------------

# "sfcompute"  — SF Compute nodes (no public IP, uses the sf CLI)
# "direct"     — Any VM with a public IP (AWS, GCP, Azure, RunPod, Vast.ai...)
COMPUTE_PROVIDER=sfcompute

# HuggingFace token to download models
HF_TOKEN=<token>

# -----------------------------------------------------------------------------
# SF Compute settings (only used when COMPUTE_PROVIDER=sfcompute)
# -----------------------------------------------------------------------------

# The node name shown in: sf nodes list
# e.g. the name you gave when running: sf nodes create <name> ...
COMPUTE_NODE_NAME=

# SF Compute SSH setup:
#   1. Your public key must be injected via cloud-init at node creation/redeploy:
#        sf nodes redeploy <name> --user-data-file ./scripts/startup.yaml
#   2. Then connect with: sf nodes ssh root@<name>  OR  ./scripts/remote.sh ssh

# -----------------------------------------------------------------------------
# Direct SSH settings (only used when COMPUTE_PROVIDER=direct)
# -----------------------------------------------------------------------------

# IP address or hostname of the remote VM
COMPUTE_HOST=

# SSH username (SF Compute=root, AWS=ubuntu or ec2-user, GCP=your-username)
COMPUTE_USER=root

# Path to your SSH private key
COMPUTE_KEY=~/.ssh/id_ed25519

# SSH port (default 22; some providers use custom ports)
COMPUTE_PORT=22

# -----------------------------------------------------------------------------
# Remote Paths
# -----------------------------------------------------------------------------

# Working directory on the remote VM (created automatically if missing)
REMOTE_DIR=/root/emotion-detection-action

# -----------------------------------------------------------------------------
# Training Settings
# -----------------------------------------------------------------------------

# PyTorch device on the remote VM: cuda | cpu
COMPUTE_DEVICE=cuda

# Number of GPUs to use for training (1 = single GPU, 8 = full node)
# When > 1, training scripts use: torchrun --nproc_per_node=TRAIN_NUM_GPUS
TRAIN_NUM_GPUS=8

# Batch size *per GPU* for Phase 1 — effective batch = TRAIN_BATCH_SIZE × TRAIN_NUM_GPUS
# H100 handles 16–32 per GPU comfortably for AffectNet ViT + emotion2vec
TRAIN_BATCH_SIZE=16

# Batch size *per GPU* for Phase 2 — smaller than Phase 1 because gradients now
# flow through the ViT backbone layers as well, increasing memory usage
TRAIN_BATCH_SIZE_PHASE2=8

# DataLoader worker processes per GPU (4 is good on Linux NVMe; 0=main thread)
TRAIN_NUM_WORKERS=4

# Training epochs per phase
TRAIN_EPOCHS_PHASE1=20
TRAIN_EPOCHS_PHASE2=10

# Backbone selection (must match between Phase 1 and Phase 2)
# affectnet_vit = recommended (AffectNet-pretrained ViT, task-aligned)
# videomae / vivit = alternative options (require more epochs to converge)
TRAIN_VIDEO_MODEL=affectnet_vit
# emotion2vec = recommended (pre-trained on IEMOCAP, MSP-Podcast, RAVDESS, CREMA-D)
# ast = alternative mel-spectrogram option
TRAIN_AUDIO_MODEL=emotion2vec

# Number of top ViT encoder layers to unfreeze during Phase 2 (2–6 recommended)
# 4 = default, good for most datasets
# 6 = use if your dataset is large (>5k clips) or diverges from AffectNet
# 0 = freeze entire ViT (Phase 2 only updates fusion layers — safe but conservative)
TRAIN_UNFREEZE_LAYERS=4

# Enable video augmentation during training (flip + brightness jitter)
# Applied to Phase 1; Phase 2 is always light-touch (no augment) for stability
TRAIN_AUGMENT=true

# -----------------------------------------------------------------------------
# Learning rate settings
# -----------------------------------------------------------------------------

# Base learning rate for Phase 1 (fusion layers + heads only — backbones frozen)
# Do NOT use linear LR scaling with frozen backbones — the linear scaling rule is
# designed for full-model training. Set TRAIN_SCALE_LR=false to disable it.
# Recommended: 2e-4 (4× lower than the default scaled value of 8e-4)
TRAIN_LR_PHASE1=2e-4
TRAIN_SCALE_LR=false

# Warmup epochs before the cosine schedule takes over (longer = smoother start)
TRAIN_WARMUP_EPOCHS=2

# AdamW weight decay — higher value = more regularisation for small datasets
TRAIN_WEIGHT_DECAY=1e-3

# Per-class loss weights for the 8 emotion classes (corrects AffectNet imbalance)
# Order: angry, disgusted, fearful, happy, neutral, sad, surprised, unclear
# These are AffectNet's recommended inverse-frequency weights
TRAIN_CLASS_WEIGHTS=5.70,35.50,20.50,1.00,1.90,5.50,9.60,20.50

# -----------------------------------------------------------------------------
# Data Sync
# -----------------------------------------------------------------------------

# Local path to combined dataset (relative to project root)
LOCAL_DATA_DIR=./data/combined

# Set to "true" to skip uploading data (useful if already on the remote VM)
SKIP_DATA_SYNC=false

# =============================================================================
# Quick-start by provider
# =============================================================================
#
# ── SF Compute ──────────────────────────────────────────────────────────────
#   COMPUTE_PROVIDER=sfcompute
#   COMPUTE_NODE_NAME=<your-node-name>   # from: sf nodes list
#
# ── AWS EC2 (p5 H100 / p3 A100) ─────────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<ec2-public-ip>
#   COMPUTE_USER=ubuntu                  # or ec2-user for Amazon Linux
#   COMPUTE_KEY=~/.ssh/your-aws-key.pem
#
# ── Google Cloud (A3 H100 / A2 A100) ────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<gcp-external-ip>
#   COMPUTE_USER=<your-gcp-username>
#   COMPUTE_KEY=~/.ssh/google_compute_engine
#
# ── Azure (NC H100 v5) ───────────────────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<azure-public-ip>
#   COMPUTE_USER=azureuser
#   COMPUTE_KEY=~/.ssh/id_rsa
#
# ── RunPod / Vast.ai / Lambda Labs ───────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<vm-ip>
#   COMPUTE_USER=root
#   COMPUTE_KEY=~/.ssh/id_ed25519
#   COMPUTE_PORT=<custom-port-from-dashboard>
