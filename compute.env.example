# =============================================================================
# Remote Compute Configuration — TEMPLATE
# =============================================================================
# Copy this to `compute.env` and fill in your values.
# `compute.env` is gitignored — never commit it.
#
# Works with SF Compute, AWS EC2, GCP, Azure, RunPod, Vast.ai, Lambda Labs...
# =============================================================================

# -----------------------------------------------------------------------------
# Provider
# -----------------------------------------------------------------------------

# "sfcompute"  — SF Compute nodes (no public IP, uses the sf CLI)
# "direct"     — Any VM with a public IP (AWS, GCP, Azure, RunPod, Vast.ai...)
COMPUTE_PROVIDER=sfcompute

# -----------------------------------------------------------------------------
# SF Compute settings (only used when COMPUTE_PROVIDER=sfcompute)
# -----------------------------------------------------------------------------

# The node name shown in: sf nodes list
# e.g. the name you gave when running: sf nodes create <name> ...
COMPUTE_NODE_NAME=

# SF Compute SSH setup:
#   1. Your public key must be injected via cloud-init at node creation/redeploy:
#        sf nodes redeploy <name> --user-data-file ./scripts/startup.yaml
#   2. Then connect with: sf nodes ssh root@<name>  OR  ./scripts/remote.sh ssh

# -----------------------------------------------------------------------------
# Direct SSH settings (only used when COMPUTE_PROVIDER=direct)
# -----------------------------------------------------------------------------

# IP address or hostname of the remote VM
COMPUTE_HOST=

# SSH username (SF Compute=root, AWS=ubuntu or ec2-user, GCP=your-username)
COMPUTE_USER=root

# Path to your SSH private key
COMPUTE_KEY=~/.ssh/id_ed25519

# SSH port (default 22; some providers use custom ports)
COMPUTE_PORT=22

# -----------------------------------------------------------------------------
# Remote Paths
# -----------------------------------------------------------------------------

# Working directory on the remote VM (created automatically if missing)
REMOTE_DIR=/root/emotion-detection-action

# -----------------------------------------------------------------------------
# Training Settings
# -----------------------------------------------------------------------------

# PyTorch device on the remote VM: cuda | cpu
COMPUTE_DEVICE=cuda

# Number of GPUs to use for training (1 = single GPU, 8 = full node)
# When > 1, training scripts use: torchrun --nproc_per_node=TRAIN_NUM_GPUS
TRAIN_NUM_GPUS=8

# Batch size *per GPU* — effective batch = TRAIN_BATCH_SIZE × TRAIN_NUM_GPUS
# H100 handles 16–32 per GPU comfortably for VideoMAE+AST models
TRAIN_BATCH_SIZE=16

# DataLoader worker processes per GPU (4 is good on Linux NVMe; 0=main thread)
TRAIN_NUM_WORKERS=4

# Training epochs per phase
TRAIN_EPOCHS_PHASE1=20
TRAIN_EPOCHS_PHASE2=10

# -----------------------------------------------------------------------------
# Data Sync
# -----------------------------------------------------------------------------

# Local path to combined dataset (relative to project root)
LOCAL_DATA_DIR=./data/combined

# Set to "true" to skip uploading data (useful if already on the remote VM)
SKIP_DATA_SYNC=false

# =============================================================================
# Quick-start by provider
# =============================================================================
#
# ── SF Compute ──────────────────────────────────────────────────────────────
#   COMPUTE_PROVIDER=sfcompute
#   COMPUTE_NODE_NAME=<your-node-name>   # from: sf nodes list
#
# ── AWS EC2 (p5 H100 / p3 A100) ─────────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<ec2-public-ip>
#   COMPUTE_USER=ubuntu                  # or ec2-user for Amazon Linux
#   COMPUTE_KEY=~/.ssh/your-aws-key.pem
#
# ── Google Cloud (A3 H100 / A2 A100) ────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<gcp-external-ip>
#   COMPUTE_USER=<your-gcp-username>
#   COMPUTE_KEY=~/.ssh/google_compute_engine
#
# ── Azure (NC H100 v5) ───────────────────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<azure-public-ip>
#   COMPUTE_USER=azureuser
#   COMPUTE_KEY=~/.ssh/id_rsa
#
# ── RunPod / Vast.ai / Lambda Labs ───────────────────────────────────────────
#   COMPUTE_PROVIDER=direct
#   COMPUTE_HOST=<vm-ip>
#   COMPUTE_USER=root
#   COMPUTE_KEY=~/.ssh/id_ed25519
#   COMPUTE_PORT=<custom-port-from-dashboard>
